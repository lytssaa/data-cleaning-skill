{
  "schema_rules": {
    "age": "int",
    "income": "float",
    "join_date": "datetime"
  },
  "semantic_rules": {
    "age": {
      "invalid": [-5, -1],
      "suspicious": [150]
    },
    "rooms": {
      "invalid": [-1],
      "suspicious": [0]
    }
  },
  "missing_rules": {
    "income": {
      "sentinel": [-999]
    },
    "membership_years": {
      "sentinel": [9999]
    }
  },
  "business_rules": {
    "height_cm": {
      "replace_values": [0],
      "fill": "median",
      "missing_means": "impossible value"
    }
  },
  "outlier_rules": {
    "income": {
      "method": "percentile",
      "threshold": 0.995
    },
    "age": {
      "method": "iqr"
    }
  },
  "outlier_method": "iqr",
  "iqr_k": 1.5,
  "expand_nested": false,
  "db_table": "",
  "explain": true
}
